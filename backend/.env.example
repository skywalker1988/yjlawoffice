# ── 서버 설정 ──
PORT=5000

# ── CORS 허용 도메인 (쉼표 구분) ──
# ALLOWED_ORIGINS=https://example.com,https://www.example.com

# ── 파일 저장 경로 (기본: backend/data) ──
# STORAGE_PATH=/var/data/yjlaw

# ── CSRF 시크릿 (미설정 시 서버 시작마다 랜덤 생성, 프로덕션에서는 고정 권장) ──
# CSRF_SECRET=your-random-secret-here

# ── 관리자 초기 계정 (최초 실행 시 자동 생성, 8자 이상 필수) ──
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=   # ← 반드시 안전한 비밀번호로 변경 (미설정 시 계정 생성 안됨)

# ── Google Apps Script 웹훅 URL (상담 알림) ──
APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
